# Webex Authentication (choose one)
# Option A: OAuth (recommended)
WEBEX_CLIENT_ID=your_client_id
WEBEX_CLIENT_SECRET=your_client_secret
# Option B: Personal access token (expires after 12h)
# WEBEX_ACCESS_TOKEN=your_token_here

# Your Webex email (used to identify your messages in triage)
SUMMARY_USER_EMAIL=you@example.com

# Briefing delivery
SUMMARY_DELIVERY=webex          # webex, email, or both
SUMMARY_WEBEX_SPACE=My Webex Summaries  # Space to post briefings to
# SUMMARY_EMAIL_TO=you@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Claude API (for automated triage scripts)
# If using AWS Bedrock:
# CLAUDE_CODE_USE_BEDROCK=true
# AWS_PROFILE=your_profile
# If using direct API:
# ANTHROPIC_API_KEY=your_key
